# copy to .env and fill in
# .env is gitignored — don't commit the real file

# Snowflake (used by the loader and dashboard)
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=TAXI_PIPELINE
SNOWFLAKE_SCHEMA=PUBLIC

# Airflow — only needed for local UID matching on Linux
# on mac/windows leave this as is
AIRFLOW_UID=50000

# used by the streaming generator (optional)
STREAM_BATCH_SIZE=5000
STREAM_INTERVAL_SECONDS=2

# Spark tuning (optional — defaults in code are fine)
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=2g
